  "item": [
    {
      "name": "https://myassetshub.com/api/v1/auth/login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Basic response logging",
              "pm.test(\"Response received\", function () {",
              "  pm.expect(pm.response.code).to.be.a('number');",
              "});",
              "",
              "// Safe debug logging (pm.console is not supported in Postman Sandbox)",
              "const status = pm.response.code;",
              "let bodyText = \"\";",
              "try {",
              "  bodyText = pm.response.text() || \"\";",
              "} catch (e) {",
              "  bodyText = \"\";",
              "}",
              "",
              "try {",
              "  console.log(`[login] Status: ${status}`);",
              "  console.log(`[login] Response headers: ${JSON.stringify(pm.response.headers.toObject())}`);",
              "  console.log(`[login] Body (first 500 chars): ${bodyText ? bodyText.slice(0, 500) : '<empty>'}`);",
              "} catch (e) {",
              "  // ignore logging errors",
              "}",
              "",
              "// Handle JSON parsing safely",
              "let json = null;",
              "try {",
              "  // Only attempt JSON parsing when body has something",
              "  if (bodyText && bodyText.trim().length) {",
              "    json = pm.response.json();",
              "  }",
              "} catch (e) {",
              "  json = null;",
              "}",
              "",
              "pm.test(\"Status is expected (2xx/4xx/5xx)\", function () {",
              "  pm.expect([200, 201, 400, 401, 403, 404, 422, 500, 502, 503]).to.include(status);",
              "});",
              "",
              "// Fail explicitly on server errors",
              "pm.test(\"No 5xx server error\", function () {",
              "  pm.expect(String(status).startsWith('5'), `Server error ${status} received`).to.eql(false);",
              "});",
              "",
              "// Success: token presence + extraction",
              "if (status === 200 || status === 201) {",
              "  pm.test(\"Login success response contains a token\", function () {",
              "    pm.expect(json, \"Expected JSON body\").to.be.an('object');",
              "",
              "    // Common token field patterns",
              "    const token = json?.token || json?.access_token || json?.data?.token || json?.data?.access_token;",
              "    pm.expect(token, \"token/access_token not found in response\").to.be.a('string').and.not.be.empty;",
              "",
              "    // Prefer environment token if an environment is active; otherwise use global auth_token",
              "    try {",
              "      const envName = pm.environment?.name;",
              "      if (envName) {",
              "        pm.environment.set('token', token);",
              "      } else {",
              "        pm.globals.set('auth_token', token);",
              "      }",
              "    } catch (e) {",
              "      // fall back to global",
              "      pm.globals.set('auth_token', token);",
              "    }",
              "  });",
              "}",
              "",
              "// Common validation / auth failures",
              "if ([400, 401, 403, 404, 422].includes(status)) {",
              "  pm.test(\"Client error has a JSON error message/shape\", function () {",
              "    pm.expect(json, \"Expected JSON error body\").to.be.an('object');",
              "    const msg = json?.message || json?.error || json?.errors;",
              "    pm.expect(msg, \"No message/error/errors found\").to.exist;",
              "  });",
              "}",
              "",
              "// 5xx test already covers server errors; keep a marker test for visibility",
              "if (String(status).startsWith('5')) {",
              "  pm.test(\"Server error returned (investigate backend logs)\", function () {",
              "    pm.expect(true).to.eql(true);",
              "  });",
              "}",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
